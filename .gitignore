# Secrets
.env
.env.local
*.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Data / logs
# state.json, macro_cache.json, and history.sqlite must be tracked so the
# GitHub Actions workflow can persist them across runs (each runner is
# otherwise stateless). Other data files stay ignored.
data/*
!data/.gitkeep
!data/state.json
!data/macro_cache.json
!data/fred_cache.json
!data/history.sqlite
!data/x_monitor_circuit.json
*.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
scripts/.codex_consult.md

# Claude-related local state (worktrees, session cache, prompts).
# Without this, a stray `git add .` would vendor a second checkout of the
# repo plus runtime data inside .claude/worktrees/.
.claude/
*.codex_consult*.md
