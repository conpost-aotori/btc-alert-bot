# 翻訳・要約用 (Gemini 1500 RPD/日 無料枠)
GEMINI_API_KEY=

# FRED マクロ背景指標 (DXY/米金利/VIX/FedFunds、daily更新、12hキャッシュ)。
# 取得: https://fredaccount.stlouisfed.org/apikeys (無料登録)
# 未設定でも BOT は動作する (FRED factor が省略されるだけ)。
FRED_API_KEY=

# X (Twitter) account 監視 via Nitter RSS (best-effort、opt-in)。
# 例: NITTER_ACCOUNTS=WatcherGuru,WuBlockchain,lookonchain
# 空 / 未設定 → 機能オフ。Nitter は不安定なので使えない時期もあるが、
# その場合も BOT 全体は動作する (silent skip)。
NITTER_ACCOUNTS=
# 任意: Nitter インスタンス上書き (カンマ区切り URL)。
NITTER_INSTANCES=

# X API (投稿用、polymarket-BOT と同アカウント)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Discord Webhook (アラート配信先)
DISCORD_WEBHOOK_URL=

LOG_LEVEL=INFO
DRY_RUN=false

# true で X (Twitter) にも投稿。Discord専用でテスト中なら false 推奨。
ENABLE_X_POST=false
