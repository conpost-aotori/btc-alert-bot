# 翻訳・要約用 (Gemini 1500 RPD/日 無料枠)
GEMINI_API_KEY=

# FRED マクロ背景指標 (DXY/米金利/VIX/FedFunds、daily更新、12hキャッシュ)。
# 取得: https://fredaccount.stlouisfed.org/apikeys (無料登録)
# 未設定でも BOT は動作する (FRED factor が省略されるだけ)。
FRED_API_KEY=

# Grok Live Search via X — 主要 X 検索ソース。発火時に Grok が X を
# AI 検索 → 蓋然性の高い 1-2 件の事象を factor 化して要約に組み込む。
# https://console.x.ai/ で API キー取得 ($5 デポジット必要、~$0.5/月)。
# 同じキーを jp_translator chain の Grok フォールバックでも使用。
# 未設定なら silent skip → Nitter にフォールバック。
XAI_API_KEY=
# 任意: モデル上書き。デフォルト grok-4-fast (安価で十分)。
XAI_MODEL=

# Nitter RSS for X (Grok のフォールバックとして残存、現状ほぼ動かない)。
# Grok がメインになるので NITTER_ACCOUNTS は空のままで OK。
# どうしても Grok 不可で X 監視したい場合のみアカウントを列挙:
#   例: NITTER_ACCOUNTS=WatcherGuru,WuBlockchain,lookonchain
NITTER_ACCOUNTS=
NITTER_INSTANCES=

# X API (投稿用、polymarket-BOT と同アカウント)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Discord Webhook (アラート配信先)
DISCORD_WEBHOOK_URL=

LOG_LEVEL=INFO
DRY_RUN=false

# true で X (Twitter) にも投稿。Discord専用でテスト中なら false 推奨。
ENABLE_X_POST=false

# --- Japanese translation chain (shared jp_translator module) ---
# 順序: Gemini → OpenAI → Grok → DeepL (fallback chain)。
# 最低 1 つ設定すれば動く (失敗時のみ次へ)。
#  1) Gemini  : 上の GEMINI_API_KEY を流用
#  2) OpenAI  : https://platform.openai.com/api-keys (paid)。GPT-4o/GPT-5 系
#  3) Grok    : 上の XAI_API_KEY を流用 (X 検索と共用)
#  4) DeepL   : https://www.deepl.com/pro-api       (free 500K char/月。:fx で終わる)
OPENAI_API_KEY=
DEEPL_API_KEY=
# 任意: モデル上書き
#JP_TRANSLATOR_GEMINI_MODEL=gemini-2.5-flash
#JP_TRANSLATOR_OPENAI_MODEL=gpt-4o-mini
#JP_TRANSLATOR_GROK_MODEL=grok-2-1212
